{
  "name": "ai-usage-bar",
  "displayName": "AI Usage Bar",
  "description": "Status bar showing AI usage for Claude Code, OpenAI Codex, and GitHub Copilot",
  "version": "0.8.0",
  "publisher": "MohammedNaeem",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mnaeem1/AI-Usage-Bar"
  },
  "bugs": {
    "url": "https://github.com/mnaeem1/AI-Usage-Bar/issues"
  },
  "homepage": "https://github.com/mnaeem1/AI-Usage-Bar#readme",
  "keywords": [
    "ai",
    "usage",
    "copilot",
    "codex",
    "claude",
    "statusbar",
    "cursor",
    "vscode"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiUsage.refresh",
        "title": "AI Usage: Refresh Now"
      },
      {
        "command": "aiUsage.signInGitHub",
        "title": "AI Usage: Sign in to GitHub (for Copilot)"
      },
      {
        "command": "aiUsage.toggleClaude",
        "title": "AI Usage: Toggle Claude Provider"
      },
      {
        "command": "aiUsage.toggleCodex",
        "title": "AI Usage: Toggle Codex Provider"
      },
      {
        "command": "aiUsage.toggleCopilot",
        "title": "AI Usage: Toggle Copilot Provider"
      }
    ],
    "configuration": {
      "title": "AI Usage Bar",
      "properties": {
        "aiUsage.refreshSeconds": {
          "type": "number",
          "default": 120,
          "minimum": 30,
          "description": "How often (in seconds) to poll usage data. Minimum 30s to avoid API rate limits."
        },
        "aiUsage.claudeMinApiMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Minimum minutes between Claude API calls to reduce Anthropic rate-limit pressure."
        },
        "aiUsage.providers.claude": {
          "type": "boolean",
          "default": true,
          "description": "Enable Claude usage tracking."
        },
        "aiUsage.providers.codex": {
          "type": "boolean",
          "default": true,
          "description": "Enable Codex usage tracking."
        },
        "aiUsage.providers.copilot": {
          "type": "boolean",
          "default": true,
          "description": "Enable Copilot usage tracking."
        },
        "aiUsage.debugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose logs in Output > AI Usage."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
